# HJATS 环境变量配置
# 复制此文件为 .env 并填入你的API密钥

# Binance 合约 API 配置
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# MongoDB 配置 (可选 - 仅当使用远程数据库时需要)
MONGODB_USER=admin
MONGODB_PASSWD=your_mongodb_password_here
MONGODB_HOST=111.229.229.135
MONGODB_PORT=27017
MONGODB_AUTH_SOURCE=admin